{
  "name": "@typetrace/cli",
  "version": "0.1.0",
  "description": "TypeScript type inference debugger — understand WHY a type became this type",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "typetrace": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc --build",
    "prepublishOnly": "tsc --build"
  },
  "keywords": [
    "typescript",
    "type-inference",
    "debugger",
    "cli",
    "types",
    "developer-tools"
  ],
  "license": "MIT",
  "author": "Eraxel.Dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/eraxel-dev/typetrace.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/eraxel-dev/typetrace#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@typetrace/graph-engine": "workspace:*",
    "@typetrace/project-loader": "workspace:*",
    "@typetrace/reporters": "workspace:*",
    "@typetrace/shared": "workspace:*",
    "@typetrace/trace-engine": "workspace:*",
    "commander": "^12.1.0"
  }
}
