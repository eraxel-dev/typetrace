"
`;

exports[`cli: trace command (text output) > traces the nested fixture and matches the text snapshot 1`] = `
"Symbol: | (T extends string ? "is-string" : "not-string")
  | (T extends number ? "is-number" : "not-number")

  Step 1  Describe<T> → T extends string ? "is-string" : "not-string"
          union member

  Step 2  T → string
          conditional check

  Step 3  T extends string ? "is-string" : "not-string" → "is-string"
          conditional true branch

  Step 4  Describe<T> → T extends number ? "is-number" : "not-number"
          union member

  Step 5  T → number
          conditional check

  Step 6  T extends number ? "is-number" : "not-number" → "is-number"
          conditional true branch


Final type: Describe<T>
"
`;

exports[`cli: trace command (text output) > traces the primitive fixture and matches the text snapshot 1`] = `
