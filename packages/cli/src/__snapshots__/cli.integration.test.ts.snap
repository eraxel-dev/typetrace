// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`cli: explain command > explains the generic-infer fixture, exits 0 and matches the snapshot 1`] = `
"T

Reason:
  T was inferred as string

Final type: T
"
`;

exports[`cli: trace command (text output) > traces the conditional-type fixture and matches the text snapshot 1`] = `
"Symbol: T extends string ? "yes" : "no"

  Step 1  T → string
          conditional check


Final type: IsString<T>
"
`;

exports[`cli: trace command (text output) > traces the generic-infer fixture and matches the text snapshot 1`] = `
"Symbol: T

  Step 1  T → string
          type parameter constrained to string


